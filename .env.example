# ─── APEX Environment Variables ───────────────────────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ── Plaid (get from dashboard.plaid.com) ─────────────────────────────────────
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret       # use sandbox for dev, production for live
PLAID_ENV=sandbox                      # sandbox | production

# ── Anthropic (AI assistant) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (SMS alerts) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx       # your Twilio number
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxx    # Twilio Verify service SID

# ── Resend (email digests) ──────────────────────────────────────────────────
RESEND_API_KEY=re_...
APEX_FROM_EMAIL=APEX Finance <digest@yourdomain.com>

# ── Rentcast (market rent estimates) ─────────────────────────────────────────
# Get at app.rentcast.io — $50/mo for 1000 calls, free tier available
RENTCAST_API_KEY=your_rentcast_key

# ── Zillow via RapidAPI (property valuations) ────────────────────────────────
# Get at rapidapi.com/apimaker/api/zillow-com1
ZILLOW_API_KEY=your_rapidapi_key

# ── Plaid Webhook ──────────────────────────────────────────────────────────
PLAID_WEBHOOK_URL=http://localhost:8000/api/plaid/webhook

# ── CORS (comma-separated allowed origins) ────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend (Vite inlines these at build time) ───────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
